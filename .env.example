# HubSpot Private App Token
# Create one at: HubSpot Settings > Integrations > Private Apps
# Scopes needed: crm.objects.contacts.read/write, crm.objects.deals.read/write, crm.objects.notes.read/write
HUBSPOT_API_TOKEN=pat-eu1-your-token-here

# Google OAuth (Gmail API)
# Get credentials at: https://console.cloud.google.com/apis/credentials
# See README.md for step-by-step OAuth setup
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Enrichment Agent
# Brave Search API — https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key
# Firecrawl — https://firecrawl.dev/
FIRECRAWL_API_KEY=your-firecrawl-api-key
# Hunter.io Email Verification — https://hunter.io/api
HUNTER_API_KEY=your-hunter-api-key
# Anthropic API (for Claude email extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key
