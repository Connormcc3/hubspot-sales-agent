# an `export` command writes one.
table.tsv
output/errors.log
output/preview.json
output/already_drafted.json
output/research-reports/*.md
output/recovery-*.md
output/analysis/*.md
output/lead-dossiers/*.md
output/prospect-dossiers/*.md
output/performance/*.md

# Keep directory structure
!output/.gitkeep
!output/research-reports/.gitkeep
!output/analysis/.gitkeep
!output/lead-dossiers/.gitkeep
!output/prospect-dossiers/.gitkeep
